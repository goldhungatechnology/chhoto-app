## ------ APPLICATION CONFIGURATION ------
ENVIRONMENT=development
PROJECT_NAME=chhoto-backend-dev
APP_URL="https://dev.api.chhoto.app"
SECRET_KEY="override_this_in_dev_environment"
AUDIT_ENABLED=True

## ------ DATABASE CONFIGURATION ------
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db_dev:5432/chhoto_db_dev"
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=chhoto_db_dev

## ------ CACHING CONFIGURATION -----
REDIS_URL=redis://redis_dev:6379/0
